# Garmin Connect Credentials
GARMIN_EMAIL=your_email@domain.com
GARMIN_PASSWORD=your_password
GARMINTOKENS=.garminconnect

# Gemini API Key (Required for Layer 2 AI interpretation)
GEMINI_API_KEY=your_gemini_api_key

# Strava OAuth2 (create app at https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Physiological Parameters
MAX_HR=189
RESTING_HR=50
CYCLING_FTP=178
RUNNING_LTHR=168
SWIM_PACE=2:00
RUNNING_ECONOMY_PENALTY=0.10

# Email Configuration
SEND_EMAIL=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_TO=your_email@gmail.com
EMAIL_FROM=your_email@gmail.com

HOME_ASSISTANT_URL   = "HOME_ASSISTANT_URL"
HOME_ASSISTANT_TOKEN = "HOME_ASSISTANT_TOKEN"

RUNNA_CALENDAR_URL=RUNNA_CALENDAR_URL